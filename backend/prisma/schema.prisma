generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  role      Role     @default(STUDENT)
  isActive  Boolean  @default(true)
  resetPasswordToken   String?  @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime @default(now())
  preferences          Json?    @default("{}")
  profilePicture       String?
  is2FAEnabled         Boolean  @default(false)
  twoFactorOTP         String?
  twoFactorExpires     DateTime?

  student       Student?
  provider      Provider?
  notifications Notification[]
  auditLogs     AuditLog[]
  sentMessages  Message[]  @relation("SentMessages")
  receivedMsgs  Message[]  @relation("ReceivedMessages")
}

enum Role {
  STUDENT
  PROVIDER
  ADMIN
}

model Student {
  id              String  @id @default(cuid())
  userId          String  @unique
  name            String
  cgpa            Float?
  incomeLevel     String?
  fieldOfStudy    String?
  location        String?
  gender          String?
  profileComplete Boolean @default(false)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  documents    Document[]
  reviews      Review[]
}

model Provider {
  id                 String             @id @default(cuid())
  userId             String             @unique
  orgName            String
  orgType            String?
  trustScore         Int                @default(0)
  verificationStatus VerificationStatus @default(PENDING)
  approvedAt         DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarships Scholarship[]
  reviews      Review[]
  transactions Transaction[]
  documents    Document[]
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Scholarship {
  id           String            @id @default(cuid())
  providerId   String
  title        String
  description  String?
  amount       Float?
  deadline     DateTime?
  criteriaJson Json?
  requirementsJson Json?
  status       ScholarshipStatus @default(DRAFT)
  createdAt    DateTime          @default(now())
  sourceUrl    String?
  isExternal   Boolean           @default(false)
  externalId   String?           @unique
  category     String?

  provider     Provider      @relation(fields: [providerId], references: [id])
  applications Application[]
  transactions Transaction[]
}

enum ScholarshipStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  CLOSED
}

model Application {
  id            String            @id @default(cuid())
  studentId     String
  scholarshipId String
  status        ApplicationStatus @default(PENDING)
  formData      Json?
  submittedAt   DateTime          @default(now())
  reviewedAt    DateTime?
  remarks       String?

  student     Student     @relation(fields: [studentId], references: [id])
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id])
  documents   Document[]
  fraudFlag   FraudFlag?
  messages    Message[]
  transactions Transaction[]

  @@unique([studentId, scholarshipId])
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEWING
  APPROVED
  REJECTED
}

model Document {
  id          String   @id @default(cuid())
  studentId   String?
  providerId  String?
  appId       String?
  fileUrl     String
  publicId    String?
  fileName    String?
  fileSize    Int?
  fileHash    String?
  docType     String
  uploadedAt  DateTime @default(now())

  student     Student?     @relation(fields: [studentId], references: [id])
  provider    Provider?    @relation(fields: [providerId], references: [id])
  application Application? @relation(fields: [appId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  studentId   String
  providerId  String
  rating      Int
  comment     String?
  isModerated Boolean  @default(false)
  createdAt   DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model FraudFlag {
  id            String   @id @default(cuid())
  applicationId String   @unique
  fraudScore    Float
  featuresJson  Json?
  status        String   @default("FLAGGED")
  flaggedAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  oldVal     Json?
  newVal     Json?
  actorId    String
  timestamp  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Message {
  id             String      @id @default(cuid())
  applicationId  String
  senderId       String
  receiverId     String
  content        String
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id])
  sender        User        @relation("SentMessages", fields: [senderId], references: [id])
  receiver      User        @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Transaction {
  id             String      @id @default(cuid())
  providerId     String
  amount         Float
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  reference      String?
  scholarshipId  String?
  applicationId  String?
  createdAt      DateTime    @default(now())

  provider      Provider     @relation(fields: [providerId], references: [id])
  scholarship   Scholarship? @relation(fields: [scholarshipId], references: [id])
  application   Application? @relation(fields: [applicationId], references: [id])
}

enum TransactionType {
  DEPOSIT
  DISBURSEMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}